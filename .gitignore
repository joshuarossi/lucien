.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store

# Claude Code local state (machine-specific)
.claude/

# Stray pi session exports (debug artifacts)
pi-session-*.html

# Large regenerable fine-tune training data — recipe is captured by each
# dataset-info.json + scripts/make-finetune-data.ts / curate-chunk-v2.ts.
benchmark/finetune/**/*.jsonl

# Chunk-v3 relabel/verify scratch + generated gold — large LLM-generated DATA,
# not code. The relabel/out/ cache + ideal-labels.json live on local disk and are
# cheaply regenerable (relabel-collect.ts from out/), so they stay out of git.
# Only the recipe is tracked: the scripts + each dataset-info.json (provenance).
benchmark/finetune/**/relabel/
benchmark/finetune/**/verify/
benchmark/finetune/**/relabel-manifest.json
benchmark/finetune/**/aggressive-merges.json
benchmark/finetune/**/ideal-labels*.json

# Chunk-eval judge-prep payloads (large per-conv prompts, regenerable via
# chunk-eval.ts judge-prep).
benchmark/results/**/judge-input-*.json
